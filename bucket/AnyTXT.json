{
    "version": "1.3.1517",
    "description": "A local document search application",
    "homepage": "https://anytxt.net",
    "license": "freeware",
    "url": "https://downloads.sourceforge.net/project/anytxt/Anytxt_1.3.2477_Windows_X86_64.exe",
    "hash": "sha1:a156dbe6b77ebbbfe5dbc30441b7b8ecae05b1fd",
    "installer": {
        "args": [
            "/verysilent",
            "/dir=\"$dir\""
        ],
        "script": "sudo taskkill /F /IM ATService.exe | Out-Null"
    },
    "persist": "config.db",
    "post_install": "Remove-Item \"$Env:Public\\Desktop\\AnyTXT*.lnk\"",
    "uninstaller": {
        "file": "unins000.exe",
        "args": "/verysilent"
    },
	"innosetup": true,
    "bin": "ATGUI.exe",
    "shortcuts": [
        [
            "ATGUI.exe",
            "AnyTXT Searcher"
        ]
    ],
    "checkver": {
        "url": "https://anytxt.net/download/",
        "regex": "Anytxt_([\\d.]+)_Windows_X86_64\\.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://sourceforge.net/projects/anytxt/files/AnyTXT_Searcher.$version_Windows_X86_64.exe"
            },
            "32bit": {
                "url": "https://sourceforge.net/projects/anytxt/files/AnyTXT_Searcher.$version_Windows_X86_32.exe"
            }
        },
}
